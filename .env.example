APP_NAME="Prodmee Slate"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

# Frontend SPA origin (used for CORS, Sanctum, share + invite links)
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# In containers, add "stderr" to LOG_STACK (or set LOG_CHANNEL=stderr) so app
# logs reach `docker compose logs` / CloudWatch, not just storage/logs.
LOG_CHANNEL=stack
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (production). For quick local runs you may use DB_CONNECTION=sqlite.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=prodmee_slate
DB_USERNAME=prodmee
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Token auth for the SPA (no cookie/stateful domains needed)
SANCTUM_STATEFUL_DOMAINS=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email: 'log' writes OTP codes to storage/logs; 'ses' in production.
# For local dev with docker-compose, MailHog is wired up automatically
# (MAIL_MAILER=smtp, MAIL_HOST=mailhog) — view mail at http://localhost:8026
MAIL_MAILER=log
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="no-reply@prodmee.app"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (S3 for files, SES for email, Secrets Manager in prod)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=prodmee-slate-files
AWS_USE_PATH_STYLE_ENDPOINT=false

# Anthropic (Sicala). The live key is normally stored encrypted in app_settings
# via the admin Settings -> API Key tab; this env var is only a fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_INPUT_PRICE=3.0
ANTHROPIC_OUTPUT_PRICE=15.0

VITE_APP_NAME="${APP_NAME}"
